# ── MoneyDNA environment variables ────────────────────────────────────────
# Copy this file to ".env" for local development and fill in real values.
# On Vercel, add these same keys under Project → Settings → Environment Variables.
# NEVER commit the real ".env" file (it is git-ignored).

# PostgreSQL connection used by the app at runtime (Supabase "Transaction"/pooled URL).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"

# Direct PostgreSQL connection used only when creating/updating tables (Supabase "Session"/direct URL).
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# Secret that signs login sessions. Generate a new one with:  npx auth secret
# (or:  openssl rand -base64 32)
AUTH_SECRET="replace-with-a-long-random-string"

# Optional: enables real Claude-powered coaching. Without it, the app falls back
# to its built-in, numbers-grounded responses. Get a key at console.anthropic.com.
ANTHROPIC_API_KEY=""
